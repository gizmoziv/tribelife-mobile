# EAS Build ignore list — mirrors .gitignore EXCEPT for google-services.json,
# which must be uploaded so Expo's prebuild can wire Firebase into the Android
# build. The file is still gitignored; it just gets sent to EAS directly.

# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native builds
ios/
android/

# Environment variables
.env
.env.local
.env.production

# Metro
.metro-health-check*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo

# Google Services — NOTE: google-services.json is intentionally NOT listed here
# so EAS uploads it for the Android build. Keep GoogleService-Info.plist ignored
# until iOS Firebase is set up.
GoogleService-Info.plist

# Claude / OMC workspace
.claude
.omc
