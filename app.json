{
  "expo": {
    "name": "TribeLife App",
    "slug": "tribelife",
    "version": "1.7.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tribelife.app",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:tribelife.app"
      ],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.410620090041-ghtee9gta3slp7insln08dddvr8ud6cr",
              "tribelife"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "TribeLife uses your location to show accurate Shabbat candle-lighting times.",
        "NSMicrophoneUsageDescription": "TribeLife needs access to your microphone to send voice messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F172A"
      },
      "splash": {
        "image": "./assets/splash-android.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F172A"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.tribelife.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tribelife.app",
              "pathPrefix": "/globe"
            },
            {
              "scheme": "https",
              "host": "tribelife.app",
              "pathPrefix": "/g/"
            },
            {
              "scheme": "https",
              "host": "tribelife.app",
              "pathPrefix": "/u/"
            },
            {
              "scheme": "https",
              "host": "tribelife.app",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "tribelife.app",
              "pathPrefix": "/org/"
            },
            {
              "scheme": "https",
              "host": "tribelife.app",
              "pathPrefix": "/org/invite/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-dev-client",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1",
          "defaultChannel": "default"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "TribeLife needs access to your photos to set your profile picture."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TribeLife uses your location to show accurate Shabbat candle-lighting times."
        }
      ],
      "@giphy/react-native-sdk",
      [
        "expo-audio",
        {
          "microphonePermission": "TribeLife needs access to your microphone to send voice messages."
        }
      ]
    ],
    "scheme": "tribelife",
    "extra": {
      "eas": {
        "projectId": "cb085a03-8ad6-428e-ab61-b0bf57ecf0fc"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cb085a03-8ad6-428e-ab61-b0bf57ecf0fc"
    }
  }
}
