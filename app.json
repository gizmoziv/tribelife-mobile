{
  "expo": {
    "name": "TribeLife App",
    "slug": "tribelife",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tribelife.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.747431558513-l69psshcds1b5r2icjbv62tun0iqtrim"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.747431558513-l69psshcds1b5r2icjbv62tun0iqtrim"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.tribelife.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-dev-client",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1",
          "defaultChannel": "default"
        }
      ],
      "expo-build-properties"
    ],
    "scheme": "tribelife",
    "extra": {
      "eas": {
        "projectId": "cb085a03-8ad6-428e-ab61-b0bf57ecf0fc"
      },
      "router": {}
    }
  }
}
